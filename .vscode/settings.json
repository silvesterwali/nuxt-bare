{
  "editor.formatOnSave": false,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit"
  },
  "files.associations": {
    "*.vue": "vue",
    "*.ts": "typescript",
    "*.js": "javascript"
  },
  "typescript.preferences.includePackageJsonAutoImports": "on",
  "i18n-ally.localesPaths": ["i18n", "i18n/locales"]
}
