{
  "name": "nuxt-bare",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "format:fix": "oxfmt --write",
    "typecheck": "nuxt typecheck",
    "test": "NODE_ENV=test vitest run",
    "test:watch": "NODE_ENV=test vitest --watch",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts --force",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts",
    "db:drop": "drizzle-kit drop --config=drizzle.config.ts",
    "db:check": "drizzle-kit check --config=drizzle.config.ts",
    "db:up": "drizzle-kit up --config=drizzle.config.ts",
    "db:seed": "tsx server/db/seed.ts",
    "db:init": "tsx server/db/init.ts",
    "db:reset": "rm -f database.db && pnpm db:push && pnpm db:seed"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.98",
    "@iconify-json/simple-icons": "^1.2.74",
    "@nuxt/hints": "1.0.0",
    "@nuxt/image": "2.0.0",
    "@nuxt/scripts": "0.13.2",
    "@nuxt/test-utils": "4.0.0",
    "@nuxt/ui": "^4.5.1",
    "@nuxtjs/google-fonts": "3.2.0",
    "@nuxtjs/i18n": "^10.2.3",
    "@nuxtjs/mcp-toolkit": "0.8.0",
    "@nuxtjs/seo": "3.4.0",
    "@pinia/colada": "^1.0.0",
    "@pinia/colada-nuxt": "0.3.2",
    "@pinia/nuxt": "0.11.3",
    "@types/nodemailer": "^7.0.11",
    "@vueuse/nuxt": "^14.2.1",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "evlog": "2.8.0",
    "nitropack": "^2.13.1",
    "nodemailer": "^8.0.2",
    "nuxt": "^4.4.2",
    "nuxt-auth-utils": "0.5.29",
    "nuxt-authorization": "0.3.5",
    "nuxt-email-renderer": "^2.5.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@adonisjs/hash": "^10.0.0",
    "@faker-js/faker": "^10.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "drizzle-kit": "^0.31.10",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.4",
    "nitro-test-utils": "^1.0.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.6"
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "@parcel/watcher"
    ],
    "overrides": {
      "vite": "8.0.0-beta.0"
    }
  }
}
